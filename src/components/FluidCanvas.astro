---
---

<canvas id="fluid-canvas" class="absolute inset-0 w-full h-full"></canvas>

<script>
  const canvas = document.getElementById('fluid-canvas');
  const ctx = canvas.getContext('2d');
  
  let width, height;
  let mouse = { x: 0, y: 0, prevX: 0, prevY: 0, moving: false };
  let particles = [];
  let animationId;
  let lastTime = 0;
  
  const CONFIG = {
    particleCount: 600,
    particleLife: 100,
    fadeSpeed: 0.015,
    splatRadius: 50,
    velocityScale: 0.7,
    roseColor: [184, 128, 114],
    lightRoseColor: [212, 168, 154],
    creamColor: [250, 246, 243],
  };

  function resize() {
    width = canvas.width = canvas.offsetWidth;
    height = canvas.height = canvas.offsetHeight;
  }

  class Particle {
    constructor(x, y, vx, vy) {
      this.x = x;
      this.y = y;
      this.vx = vx;
      this.vy = vy;
      this.life = CONFIG.particleLife;
      this.maxLife = CONFIG.particleLife;
      this.size = Math.random() * 2.5 + 0.5;
      this.colorType = Math.random() > 0.5 ? 'rose' : 'lightRose';
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.vx *= 0.98;
      this.vy *= 0.98;
      this.life--;
      const angle = Math.sin(this.x * 0.01 + this.y * 0.01) * 0.1;
      this.vx += Math.cos(angle) * 0.08;
      this.vy += Math.sin(angle) * 0.08;
    }

    draw(ctx) {
      const alpha = (this.life / this.maxLife) * 0.4;
      const color = this.colorType === 'rose' ? CONFIG.roseColor : CONFIG.lightRoseColor;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size * (this.life / this.maxLife), 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${color[0]}, ${color[1]}, ${color[2]}, ${alpha})`;
      ctx.fill();
    }
  }

  function createSplat(x, y, vx, vy) {
    const count = Math.min(12, Math.abs(vx) + Math.abs(vy));
    for (let i = 0; i < count; i++) {
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 2.5 + 0.5;
      const px = x + (Math.random() - 0.5) * CONFIG.splatRadius;
      const py = y + (Math.random() - 0.5) * CONFIG.splatRadius;
      particles.push(new Particle(
        px, py,
        vx * 0.25 + Math.cos(angle) * speed,
        vy * 0.25 + Math.sin(angle) * speed
      ));
    }
  }

  function animate(currentTime) {
    animationId = requestAnimationFrame(animate);
    if (currentTime - lastTime < 16) return;
    lastTime = currentTime;

    // Fade to cream background
    ctx.fillStyle = `rgba(250, 246, 243, ${CONFIG.fadeSpeed})`;
    ctx.fillRect(0, 0, width, height);

    if (Math.random() < 0.08) {
      particles.push(new Particle(
        Math.random() * width,
        Math.random() * height,
        (Math.random() - 0.5) * 0.3,
        (Math.random() - 0.5) * 0.3
      ));
    }

    if (mouse.moving) {
      const dx = mouse.x - mouse.prevX;
      const dy = mouse.y - mouse.prevY;
      const speed = Math.sqrt(dx * dx + dy * dy);
      if (speed > 2) {
        createSplat(mouse.x, mouse.y, dx * CONFIG.velocityScale, dy * CONFIG.velocityScale);
      }
      mouse.prevX = mouse.x;
      mouse.prevY = mouse.y;
      mouse.moving = false;
    }

    particles = particles.filter(p => p.life > 0);
    particles.forEach(p => {
      p.update();
      p.draw(ctx);
    });
  }

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
    mouse.moving = true;
  });

  canvas.addEventListener('touchmove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    mouse.x = touch.clientX - rect.left;
    mouse.y = touch.clientY - rect.top;
    mouse.moving = true;
  }, { passive: true });

  resize();
  window.addEventListener('resize', resize);
  
  // Initial cream fill
  ctx.fillStyle = '#FAF6F3';
  ctx.fillRect(0, 0, width, height);
  
  animate(0);

  window.addEventListener('beforeunload', () => {
    cancelAnimationFrame(animationId);
  });
</script>
