---
const businessHours = [
  { day: '週一', hours: '09:00 - 21:00' },
  { day: '週二', hours: '09:00 - 21:00' },
  { day: '週三', hours: '09:00 - 21:00' },
  { day: '週四', hours: '09:00 - 21:00' },
  { day: '週五', hours: '09:00 - 21:00' },
  { day: '週六', hours: '09:00 - 21:00' },
  { day: '週日', hours: '09:00 - 21:00' },
];

const contactInfo = [
  {
    label: '電話',
    value: '0986-132-728',
    href: 'tel:0986132728',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
  {
    label: 'LINE',
    value: '0970177878',
    href: 'https://line.me/ti/p/0970177878',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
  },
  {
    label: '地址',
    value: '桃園市桃園區南平路181巷6號1樓',
    href: 'https://maps.google.com/?q=桃園市桃園區南平路181巷6號',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---

<section id="contact" class="relative w-full py-24 md:py-32 bg-cream-dark overflow-hidden">
  <div class="section-container relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16 md:mb-24">
      <p class="text-rose text-xs tracking-ultra-wide uppercase mb-4">Contact</p>
      <h2 class="font-serif text-brown text-4xl md:text-5xl lg:text-6xl font-light mb-6">
        聯絡我們
      </h2>
      <p class="text-brown-muted text-base max-w-lg mx-auto">
        全預約制，歡迎提前預約您的專屬護理時間
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Contact Info -->
      <div class="contact-info">
        <h3 class="text-brown text-2xl font-light mb-8">預約資訊</h3>
        
        <div class="space-y-6 mb-12">
          {contactInfo.map((item) => (
            <a 
              href={item.href}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="group flex items-start gap-4"
            >
              <div class="text-rose mt-0.5">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <p class="text-brown-muted text-xs tracking-ultra-wide uppercase mb-1">{item.label}</p>
                <p class="text-brown group-hover:text-rose transition-colors duration-300">{item.value}</p>
              </div>
            </a>
          ))}
        </div>
        
        <!-- Business Hours -->
        <div class="border-t border-cream-deeper pt-8">
          <h4 class="text-brown-muted text-xs tracking-ultra-wide uppercase mb-6">營業時間</h4>
          <div class="grid grid-cols-2 gap-3">
            {businessHours.map((item) => (
              <div class="flex justify-between items-center py-2 border-b border-cream-deeper/50">
                <span class="text-brown-muted text-sm">{item.day}</span>
                <span class="text-brown text-sm">{item.hours}</span>
              </div>
            ))}
          </div>
          <p class="text-rose text-sm mt-4">全年無休 · 全預約制</p>
        </div>
      </div>
      
      <!-- Contact Form -->
      <div class="contact-form bg-white border border-cream-deeper rounded-2xl p-8 md:p-10 shadow-sm">
        <h3 class="text-brown text-2xl font-light mb-2">線上預約</h3>
        <p class="text-brown-muted text-sm mb-8">填寫以下表單，我們將盡快與您聯繫確認</p>
        
        <form class="space-y-6" onsubmit="event.preventDefault(); alert('感謝您的預約！我們將盡快與您聯繫確認。');">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label class="block text-brown-muted text-xs tracking-ultra-wide uppercase mb-2">姓名</label>
              <input 
                type="text" 
                required
                class="w-full bg-cream border border-cream-deeper text-brown px-4 py-3 text-sm rounded-lg focus:border-rose focus:outline-none transition-colors duration-300"
                placeholder="您的姓名"
              />
            </div>
            <div>
              <label class="block text-brown-muted text-xs tracking-ultra-wide uppercase mb-2">電話</label>
              <input 
                type="tel" 
                required
                class="w-full bg-cream border border-cream-deeper text-brown px-4 py-3 text-sm rounded-lg focus:border-rose focus:outline-none transition-colors duration-300"
                placeholder="聯絡電話"
              />
            </div>
          </div>
          
          <div>
            <label class="block text-brown-muted text-xs tracking-ultra-wide uppercase mb-2">LINE ID</label>
            <input 
              type="text" 
              class="w-full bg-cream border border-cream-deeper text-brown px-4 py-3 text-sm rounded-lg focus:border-rose focus:outline-none transition-colors duration-300"
              placeholder="LINE ID（選填）"
            />
          </div>
          
          <div>
            <label class="block text-brown-muted text-xs tracking-ultra-wide uppercase mb-2">預約項目</label>
            <select 
              required
              class="w-full bg-cream border border-cream-deeper text-brown px-4 py-3 text-sm rounded-lg focus:border-rose focus:outline-none transition-colors duration-300 appearance-none cursor-pointer"
            >
              <option value="">請選擇預約項目</option>
              <option value="facial">臉部護理（清粉刺/煥膚）</option>
              <option value="spa">身體SPA（經絡按摩/精油）</option>
              <option value="waxing">熱蠟除毛</option>
              <option value="skincare">敏感肌修護</option>
              <option value="prenatal">孕婦護理</option>
              <option value="other">其他諮詢</option>
            </select>
          </div>
          
          <div>
            <label class="block text-brown-muted text-xs tracking-ultra-wide uppercase mb-2">備註</label>
            <textarea 
              rows="4"
              class="w-full bg-cream border border-cream-deeper text-brown px-4 py-3 text-sm rounded-lg focus:border-rose focus:outline-none transition-colors duration-300 resize-none"
              placeholder="請描述您的需求或想預約的時間"
            ></textarea>
          </div>
          
          <button type="submit" class="btn-solid w-full">
            送出預約
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      
      gsap.fromTo('.contact-info', 
        { opacity: 0, x: -40 },
        {
          opacity: 1,
          x: 0,
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.contact-info',
            start: 'top 80%',
            toggleActions: 'play none none none',
          }
        }
      );
      
      gsap.fromTo('.contact-form', 
        { opacity: 0, x: 40 },
        {
          opacity: 1,
          x: 0,
          duration: 0.8,
          delay: 0.2,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.contact-form',
            start: 'top 80%',
            toggleActions: 'play none none none',
          }
        }
      );
    }
  });
</script>
